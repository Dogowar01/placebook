{
  "name": "Placebook",
  "short_name": "Placebook",
  "description": "Your personal location scrapbook",
  "start_url": "/placebook/",
  "scope": "/placebook/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#4F46E5",
  "theme_color": "#4F46E5",
  "share_target": {
    "action": "/placebook/",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "icons": [
    {
      "src": "icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icons/icon-180.png",
      "sizes": "180x180",
      "type": "image/png",
      "purpose": "any"
    }
  ]
}
